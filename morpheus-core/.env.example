# Variáveis de ambiente do morpheus-core.
# Copie para .env e preencha com valores reais — .env nunca é versionado.

# Conexão com o PostgreSQL. OBRIGATÓRIA: a API falha ao subir sem ela,
# informando qual variável falta e o formato esperado.
MORPHEUS_BANCO_CONEXAO=Host=localhost;Port=5432;Database=morpheus;Username=morpheus;Password=troque-esta-senha

# Observabilidade (opcional). Em dev, o appsettings.Development.json já aponta os
# traces para o Seq local. Em produção, aponte o OTLP para o seu APM — Datadog,
# Elastic, Grafana Tempo — sem tocar em código. Protocolo: grpc ou httpprotobuf.
# Rastreamento__EndpointOtlp=https://otlp.suaapm.exemplo/v1/traces
# Rastreamento__ProtocoloOtlp=httpprotobuf

# Limite de requisições por origem nas rotas de autenticação (cadastro, login e
# recuperação de senha), por minuto. Opcional; padrão 20. Aperte atrás de CDN,
# afrouxe se muitos usuários compartilham um IP de saída (NAT de escritório).
# LimiteDeAutenticacao__RequisicoesPorMinuto=20

# E-mail transacional (recuperação de senha e confirmação de cadastro). Qualquer
# SMTP compatível serve: provedor próprio, ou o relay SMTP de SES/SendGrid/Postmark.
# Sem rede em dev/CI: a suíte de testes substitui esta porta por um dublê, então
# nada aqui é obrigatório para rodar `dotnet test`. Em produção, a ausência de
# Host/Remetente só falha no primeiro envio, não na subida da aplicação.
# EmailTransacional__Host=smtp.seuprovedor.exemplo
# EmailTransacional__Porta=587
# EmailTransacional__Usuario=usuario-smtp
# EmailTransacional__Senha=troque-esta-senha
# EmailTransacional__Remetente=nao-responda@suaimobiliaria.exemplo
# EmailTransacional__NomeDoRemetente=Morpheus
# EmailTransacional__UrlDoPainel=https://painel.suaimobiliaria.exemplo
