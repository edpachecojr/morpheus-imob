{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": {
      "Seq": {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    }
  },
  "Rastreamento": {
    "EndpointOtlp": "http://localhost:5341/ingest/otlp/v1/traces",
    "ProtocoloOtlp": "httpprotobuf"
  }
}
